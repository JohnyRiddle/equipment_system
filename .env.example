DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
APP_VERSION=0.1.12
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
DJANGO_TIME_ZONE=Asia/Novosibirsk

# Production examples:
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=ays-crm.ru,www.ays-crm.ru
# DJANGO_CSRF_TRUSTED_ORIGINS=https://ays-crm.ru,https://www.ays-crm.ru
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SESSION_COOKIE_SECURE=1
# DJANGO_CSRF_COOKIE_SECURE=1
# DJANGO_SECURE_HSTS_SECONDS=0
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
# DJANGO_SECURE_HSTS_PRELOAD=0

POSTGRES_DB=equipment_db
POSTGRES_USER=equipment_user
POSTGRES_PASSWORD=equipment_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Leave empty or set to auto to generate QR links from the current request host.
# Set explicitly for background commands without request context:
# QR_EQUIPMENT_BASE_URL=https://ays-crm.ru/equipment
QR_EQUIPMENT_BASE_URL=auto
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when DJANGO_DEBUG=False. In local DEBUG mode the app uses a stable development key derived from DJANGO_SECRET_KEY if this is empty.
ACCESS_SECRET_KEYS=
