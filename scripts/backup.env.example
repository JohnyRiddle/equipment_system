# Copy this file to scripts/backup.env on the server and fill real values.

PROJECT_DIR=/home/ivan/equipment_system
COMPOSE_FILE=docker-compose.prod.yml
WEB_CONTAINER=equipment_web
MEDIA_PATH=backend/media

BACKUP_ROOT=/home/ivan/equipment_backups
BACKUP_RETENTION_COUNT=3

# Required when Google Drive or GitHub backup is enabled.
# Store the real value only on the server, never in Git.
BACKUP_ENCRYPTION_PASSWORD=change-this-long-password

# Google Drive backup through rclone.
# Example after `rclone config`: gdrive:equipment_system_backups
BACKUP_RCLONE_REMOTE=

# GitHub backup must be a separate private repository already cloned on the server.
# Example: /home/ivan/equipment_backups_github
BACKUP_GITHUB_REPO_DIR=
BACKUP_GITHUB_SUBDIR=backups
